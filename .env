# Email SMTP configuration (required for contact form delivery)
# ⚠️  IMPORTANT: You MUST update these values for email to work!

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false # true for 465, false for 587

# ⚠️  REPLACE THIS: Put your actual Gmail address here
EMAIL_USER=nkush3936@gmail.com

# ⚠️  REPLACE THIS: Generate an App Password from Gmail (NOT your regular password)
# How to get an App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification if not already enabled
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate a new App Password for "Mail"
# 5. Use that 16-character password here (no spaces)
EMAIL_PASS=mxdw apvt bssp ydii

# The email address that appears as the sender
EMAIL_FROM="Ivory Forum Legal <nkush3936@gmail.com>"

# Where contact form submissions should be sent (usually the same as EMAIL_USER)
CONTACT_RECEIVER_EMAIL=nkushwaha632@gmail.com